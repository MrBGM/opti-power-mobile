# Copie ce fichier vers .env (à la racine d'Opti-Power-Mobile) puis adapte l'IP.
# Trouve l'IP LAN de ton PC : ipconfig (Windows) → Adresse IPv4 (ex. 192.168.1.42)
# Pas de slash final. Redémarre Metro après modification : pnpm dev -- --clear

# ── Sync-service (port 3002) — équipements, pairing, snapshots ──────────────
# Utilisé pour /v1/mobile/equipments et /v1/pairing/*
EXPO_PUBLIC_SYNC_API_URL=http://192.168.1.42:3002

# ── Auth-service (port 3001) — authentification JWT ─────────────────────────
# Utilisé pour /api/v1/auth/login, /api/v1/auth/refresh
EXPO_PUBLIC_AUTH_API_URL=http://192.168.1.42:3001

# ── Ancienne variable (rétrocompatibilité) — pointe vers le sync-service ─────
# Conservée pour éviter des erreurs si encore présente dans une ancienne config.
# Préférer EXPO_PUBLIC_SYNC_API_URL pour les nouvelles installations.
# EXPO_PUBLIC_CLOUD_API_URL=http://192.168.1.42:3002
